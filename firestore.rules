rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) 
        && data.keys().size() <= 4
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'hydration', 'oiliness', 'acne', 'dark_spots', 'summary', 'createdAt'])
        && data.keys().size() <= 12
        && data.userId == request.auth.uid
        && data.hydration is number && data.hydration >= 0 && data.hydration <= 100
        && data.oiliness is number && data.oiliness >= 0 && data.oiliness <= 100
        && data.acne is number && data.acne >= 0 && data.acne <= 100
        && data.dark_spots is number && data.dark_spots >= 0 && data.dark_spots <= 100
        && data.summary is string && data.summary.size() <= 1000
        && data.createdAt == request.time
        && (data.get('tags', []) is list && data.get('tags', []).size() <= 20);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && (incoming().diff(resource.data).affectedKeys().hasOnly(['displayName']))
        && incoming().email == resource.data.email;

      match /scans/{scanId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(scanId) && isValidScan(incoming());
        // Scans are immutable after creation
        allow update, delete: if false;
      }
    }
  }
}
